{
  "version": "1.0",
  "ai": {
    "provider": "deepseek",
    "model": "deepseek-chat",
    "api_key_env": "DEEPSEEK_API_KEY",
    "temperature": 0.3,
    "max_tokens": 4096,
    "throttle_sec": 0,
    "analysis_concurrency": 1,
    "enrichment_concurrency": 1,
    "languages": ["zh", "en"]
  },
  "email": {
    "enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "xxx@qq.com",
    "sender_name": "Horizon Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "huggingface",
        "repo": "lerobot",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "isaac-sim",
        "repo": "IsaacLab",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "unitreerobotics",
        "repo": "unitree_ros2",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": false,
      "fetch_top_stories": 20,
      "min_score": 100
    },
    "rss": [
      {
        "name": "人形机器人与具身智能（中文）",
        "url": "https://news.google.com/rss/search?q=%E4%BA%BA%E5%BD%A2%E6%9C%BA%E5%99%A8%E4%BA%BA+OR+%E5%85%B7%E8%BA%AB%E6%99%BA%E8%83%BD+OR+%E5%8F%8C%E8%B6%B3%E6%9C%BA%E5%99%A8%E4%BA%BA&hl=zh-CN&gl=CN&ceid=CN%3Azh-Hans",
        "enabled": true,
        "category": "humanoid-zh"
      },
      {
        "name": "Humanoid Robotics News",
        "url": "https://news.google.com/rss/search?q=%22humanoid+robot%22+OR+%22bipedal+robot%22+OR+%22dexterous+manipulation%22&hl=en-US&gl=US&ceid=US%3Aen",
        "enabled": true,
        "category": "humanoid-en"
      },
      {
        "name": "The Robot Report",
        "url": "https://www.therobotreport.com/feed/",
        "enabled": true,
        "category": "humanoid-en"
      },
      {
        "name": "IEEE Spectrum Robotics",
        "url": "https://spectrum.ieee.org/feeds/topic/robotics.rss",
        "enabled": true,
        "category": "humanoid-en"
      },
      {
        "name": "arXiv Humanoid Robotics",
        "url": "https://export.arxiv.org/api/query?search_query=all%3A%22humanoid%20robot%22%20OR%20all%3A%22bipedal%20locomotion%22%20OR%20all%3A%22whole-body%20control%22&start=0&max_results=30&sortBy=submittedDate&sortOrder=descending",
        "enabled": true,
        "category": "humanoid-en"
      },
      {
        "name": "The Robot Report Podcast",
        "url": "https://feeds.soundcloud.com/users/soundcloud:users:830627836/sounds.rss",
        "enabled": true,
        "category": "long-form",
        "lookback_days": 30,
        "keywords": ["humanoid", "robot", "robotics", "embodied", "bipedal", "locomotion", "dexterous", "manipulation", "physical AI", "VLA", "Boston Dynamics", "Figure AI", "Agility Robotics", "Apptronik", "Unitree", "Optimus", "1X", "Sanctuary AI"]
      },
      {
        "name": "The Robot Brains Podcast",
        "url": "https://feeds.acast.com/public/shows/the-robot-brains",
        "enabled": true,
        "category": "long-form",
        "lookback_days": 30,
        "keywords": ["humanoid", "robot", "robotics", "embodied", "bipedal", "locomotion", "dexterous", "manipulation", "physical AI", "VLA", "Boston Dynamics", "Figure AI", "Agility Robotics", "Apptronik", "Unitree", "Optimus", "1X", "Sanctuary AI"]
      },
      {
        "name": "Lex Fridman Podcast",
        "url": "https://lexfridman.com/feed/podcast/",
        "enabled": true,
        "category": "long-form",
        "lookback_days": 30,
        "keywords": ["humanoid", "robot", "robotics", "embodied", "bipedal", "locomotion", "dexterous", "manipulation", "physical AI", "VLA", "Boston Dynamics", "Figure AI", "Agility Robotics", "Apptronik", "Unitree", "Optimus", "1X", "Sanctuary AI"]
      },
      {
        "name": "NVIDIA AI Podcast",
        "url": "https://feeds.megaphone.fm/nvidiaaipodcast",
        "enabled": true,
        "category": "long-form",
        "lookback_days": 30,
        "keywords": ["humanoid", "robot", "robotics", "embodied", "bipedal", "locomotion", "dexterous", "manipulation", "physical AI", "VLA", "Boston Dynamics", "Figure AI", "Agility Robotics", "Apptronik", "Unitree", "Optimus", "1X", "Sanctuary AI"]
      }
    ],
    "youtube": {
      "enabled": true,
      "api_key_env": "YOUTUBE_API_KEY",
      "queries": [
        "\"humanoid robot\" interview",
        "\"humanoid robotics\" podcast",
        "\"embodied AI\" interview robotics",
        "\"bipedal robot\" talk",
        "\"robot foundation model\" interview",
        "\"dexterous manipulation\" podcast",
        "人形机器人 访谈",
        "具身智能 深度对话",
        "双足机器人 访谈",
        "灵巧手 访谈"
      ],
      "lookback_days": 30,
      "max_results_per_query": 8,
      "min_duration_minutes": 20,
      "max_duration_minutes": 180,
      "min_views": 2000,
      "min_views_per_day": 200,
      "max_candidates": 12,
      "max_items": 3,
      "transcript_languages": ["en", "en-US", "zh-Hans", "zh-CN", "zh"],
      "category": "long-form"
    },
    "reddit": {
      "enabled": false,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "hot",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 50
        }
      ],
      "users": [
        {
          "username": "iamthatis",
          "enabled": true,
          "sort": "new",
          "fetch_limit": 10
        }
      ],
      "fetch_comments": 5
    },
    "twitter": {
      "enabled": false,
      "users": ["karpathy", "ylecun"],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": [
        {
          "name": "megacaps",
          "enabled": true,
          "provider": "yfinance",
          "fetch_limit": 20,
          "category": "equities",
          "symbols": ["AAPL", "MSFT", "NVDA", "GOOGL", "AMZN", "META", "TSLA"]
        }
      ]
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All", "Python", "C++"],
      "keywords": ["humanoid", "robot", "robotics", "embodied", "bipedal", "locomotion", "dexterous", "manipulation", "VLA"],
      "min_stars": 5,
      "max_items": 20
    }
  },
  "filtering": {
    "ai_score_threshold": 5.0,
    "time_window_hours": 48,
    "max_items": 15,
    "category_groups": {
      "zh_sources": {
        "name": "中文来源",
        "limit": 8,
        "categories": ["humanoid-zh"]
      },
      "en_sources": {
        "name": "英文来源",
        "limit": 8,
        "categories": ["humanoid-en"]
      }
    },
    "default_group": "open-source",
    "default_group_limit": 4
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": null,
    "request_body": {
      "msg_type": "interactive",
      "card": {
        "schema": "2.0",
        "config": {
          "wide_screen_mode": true
        },
        "header": {
          "title": {
            "tag": "plain_text",
            "content": "#{message_title}"
          },
          "template": "blue"
        },
        "body": {
          "elements": [
            {
              "tag": "markdown",
              "content": "Horizon生成结果: #{result}\nHorizon日报重要资讯数量: #{important_items}/#{all_items}"
            },
            {
              "tag": "hr"
            },
            {
              "tag": "markdown",
              "content": "#{summary}"
            }
          ]
        }
      }
    },
    "headers": ""
  }
}
